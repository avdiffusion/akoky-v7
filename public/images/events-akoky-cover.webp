<style>
/* FOND NOIR LEGER (PAS FLOU) */
.lux-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.55); /* noir léger */
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

/* POPUP BLANCHE */
.lux-popup {
  width: 600px;
  max-width: 90%;
  padding: 45px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.90);
  text-align: center;
  position: relative;
  box-shadow: 0 25px 60px rgba(0,0,0,0.35);
  animation: popUp 0.35s ease;
}

/* CROIX */
.lux-close {
  position: absolute;
  top: 15px;
  right: 20px;
  cursor: pointer;
  font-size: 18px;
  color: #999;
}

.lux-close:hover {
  color: #000;
}

/* LOGO */
.lux-logo {
  display: flex;
  justify-content: center;  /* centre horizontalement */
  align-items: center;
  margin-bottom: 25px;
  width: 100%;
}

.lux-logo img {
  width: 200px;   /* ajuste si besoin */
  height: auto;
}

/* TITRES */
.lux-popup h1 {
  font-size: 24px;
  margin-bottom: 20px;
  color: #333;
}

.lux-popup h2 {
  font-size: 20px;
  margin: 20px 0;
  color: #c28b4e;
}

/* TEXTE */
.lux-popup p {
  font-size: 15px;
  line-height: 1.6;
  color: #555;
}

/* BOUTON */
.lux-btn {
  margin-top: 30px;
  padding: 14px 36px;
  border-radius: 40px;
  border: none;
  cursor: pointer;
  font-weight: bold;
  font-size: 15px;
  background: #d1903c;
  color: white;
  transition: 0.3s ease;
}

.lux-btn:hover {
  background: #b9772f;
}

/* ANIMATION */
@keyframes popUp {
  from { transform: scale(0.92); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}
</style>

<script>
function closeLuxPopup() {
  document.getElementById("luxPopup").style.display = "none";
}

document.addEventListener("DOMContentLoaded", function() {

  const btn = document.querySelector(".lux-btn");
  btn.addEventListener("click", function() {
    closeLuxPopup();
  });

  if (!localStorage.getItem("luxPopupShown")) {

    setTimeout(function() {
      document.getElementById("luxPopup").style.display = "flex";
    }, 5000); // 5 secondes

    localStorage.setItem("luxPopupShown", "true");
  }
});
</script>
    
    
    
    
    
    
    
    
