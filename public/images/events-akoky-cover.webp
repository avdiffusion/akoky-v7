  <!-- 🚀 VITE ENTRY — NE PAS TOUCHER -->

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- 🔐 PROTECTION JS RENFORCÉE                                      -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <script>
  (function() {

    // =============================================
    // ENVIRONMENT DETECTION
    // =============================================
    const isLocalEnvironment =
      window.location.hostname === "localhost" ||
      window.location.hostname === "127.0.0.1" ||
      window.location.protocol === "file:" ||
      window.location.hostname.includes("lovable.app") ||
      window.location.hostname.includes("lovable.dev");

    if (isLocalEnvironment) return;

    // =============================================
    // RIGHT CLICK PROTECTION
    // =============================================
    document.addEventListener("contextmenu", e => {
      e.preventDefault();
    });

    // =============================================
    // DRAG & DROP PROTECTION
    // =============================================
    document.addEventListener("dragstart", e => {
      e.preventDefault();
    });

    // =============================================
    // KEYBOARD PROTECTION
    // =============================================
    document.addEventListener("keydown", function(e) {

      if (e.key === "F12") {
        e.preventDefault();
        return false;
      }

      if (e.ctrlKey || e.metaKey) {
        const k = e.key.toLowerCase();

        if (["u", "s", "p", "x"].includes(k)) {
          e.preventDefault();
          return false;
        }

        if (k === "c") {
          const selection = window.getSelection().toString();
          if (selection.length > 100) {
            e.preventDefault();
            return false;
          }
        }

        if (k === "a") {
          const target = e.target;
          if (target.tagName !== "INPUT" && target.tagName !== "TEXTAREA") {
            e.preventDefault();
            return false;
          }
        }

        if (e.shiftKey && ["i", "j"].includes(k)) {
          e.preventDefault();
          return false;
        }
      }
    });

    // =============================================
    // COPY / CUT PROTECTION
    // =============================================
    document.addEventListener("copy", e => {
      const selection = window.getSelection().toString();
      if (selection.length > 100) {
        e.preventDefault();
        if (e.clipboardData) {
          e.clipboardData.setData(
            "text/plain",
            "© AKOKY — Contenu protégé\nReproduction non autorisée — Tous droits réservés\nContact légal : legal@akoky.com\nLiberty Interactive Ltd"
          );
        }
      }
    });

    document.addEventListener("cut", e => {
      e.preventDefault();
    });

    // =============================================
    // MASS SELECTION PROTECTION
    // =============================================
    document.addEventListener("selectstart", e => {
      const selection = window.getSelection().toString();
      if (selection.length > 100) {
        e.preventDefault();
      }
    });

    // =============================================
    // IFRAME PROTECTION
    // =============================================
    if (window.top !== window.self) {
      window.top.location = window.self.location;
    }

    // =============================================
    // DEVTOOLS DETECTION — FLOUTAGE + AVERTISSEMENT
    // =============================================
    let devtoolsOpen = false;
    const threshold = 160;

    const detectDevTools = () => {
      const widthDiff  = window.outerWidth  - window.innerWidth;
      const heightDiff = window.outerHeight - window.innerHeight;

      if (widthDiff > threshold || heightDiff > threshold) {
        if (!devtoolsOpen) {
          devtoolsOpen = true;
          document.body.style.filter = "blur(8px)";
          document.body.style.pointerEvents = "none";

          if (!document.getElementById("akoky-devtools-warning")) {
            const warning = document.createElement("div");
            warning.id = "akoky-devtools-warning";
            warning.style.cssText = `
              position: fixed;
              top: 0; left: 0; right: 0; bottom: 0;
              z-index: 999999;
              background: rgba(0,0,0,0.92);
              display: flex;
              flex-direction: column;
              align-items: center;
              justify-content: center;
              text-align: center;
              font-family: 'Inter', sans-serif;
              color: #fff;
              padding: 2rem;
              pointer-events: auto;
            `;
            warning.innerHTML = `
              <div style="font-size:4rem;margin-bottom:1rem;">🔒</div>
              <h2 style="font-size:1.8rem;font-weight:900;color:#d7a86e;margin-bottom:1rem;">
                Accès non autorisé
              </h2>
              <p style="font-size:1rem;color:#ccc;max-width:500px;line-height:1.7;margin-bottom:1.5rem;">
                Ce contenu est protégé par le droit de la propriété intellectuelle.<br/>
                Toute reproduction, extraction ou modification est strictement interdite<br/>
                et passible de poursuites judiciaires.
              </p>
              <p style="font-size:0.85rem;color:#888;margin-bottom:2rem;">
                © AKOKY — Tous droits réservés<br/>
                Protégé par <strong style="color:#d7a86e;">Liberty Interactive Ltd</strong>
              </p>
              <a href="https://liberty-interactive-ltd.online"
                 target="_blank"
                 rel="noopener"
                 style="
                   color:#d7a86e;
                   text-decoration:underline;
                   font-size:0.9rem;
                   margin-bottom:2rem;
                 ">
                liberty-interactive-ltd.online
              </a>
              <button onclick="location.reload()" style="
                padding:0.8rem 2rem;
                background:linear-gradient(135deg,#d7a86e,#a86a3e);
                color:#fff;
                border:none;
                border-radius:9999px;
                font-size:1rem;
                font-weight:700;
                cursor:pointer;
              ">
                Fermer les outils de développement
              </button>
            `;
            document.body.appendChild(warning);
          }
        }
      } else {
        if (devtoolsOpen) {
          devtoolsOpen = false;
          document.body.style.filter = "";
          document.body.style.pointerEvents = "";
          const warning = document.getElementById("akoky-devtools-warning");
          if (warning) warning.remove();
        }
      }
    };

    // DevTools detection disabled - causes black screen on iOS Safari

    // =============================================
    // CONSOLE WARNING
    // =============================================
    console.clear();
    console.log(
      "%c🔒 AKOKY — CONTENU PROTÉGÉ",
      "color:#d7a86e;font-size:20px;font-weight:900;"
    );
    console.log(
      "%cCe site est protégé par le droit de la propriété intellectuelle.\nToute reproduction non autorisée est interdite et passible de poursuites.\n\n© AKOKY — Liberty Interactive Ltd\nlegal@akoky.com",
      "color:#ccc;font-size:13px;"
    );

    // =============================================
    // VISIBILITY MONITOR
    // =============================================
    document.addEventListener("visibilitychange", () => {
      if (document.hidden) {
        console.clear();
      }
    });

  })();
  </script>

